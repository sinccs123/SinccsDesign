    <script>
        import AOS from 'aos';

        AOS.init({
            once: true,
            offset: 100,
            duration: 700,
            easing: 'ease-out-cubic'
        });

        const perfilToggle = document.getElementById('perfil-toggle');
        const perfilTextoExtraWrap = document.getElementById('perfil-texto-extra-wrap');
        const perfilTextoExtra = document.getElementById('perfil-texto-extra');

        if (perfilToggle && perfilTextoExtra && perfilTextoExtraWrap) {
            perfilToggle.addEventListener('click', () => {
                const expanded = perfilToggle.getAttribute('aria-expanded') === 'true';

                if (expanded) {
                    perfilTextoExtraWrap.style.maxHeight = `${perfilTextoExtraWrap.scrollHeight}px`;

                    requestAnimationFrame(() => {
                        perfilTextoExtraWrap.style.maxHeight = '0px';
                        perfilTextoExtraWrap.classList.remove('opacity-100');
                        perfilTextoExtraWrap.classList.add('opacity-0');
                    });
                } else {
                    perfilTextoExtraWrap.style.maxHeight = `${perfilTextoExtra.scrollHeight}px`;
                    perfilTextoExtraWrap.classList.remove('opacity-0');
                    perfilTextoExtraWrap.classList.add('opacity-100');
                }

                perfilToggle.setAttribute('aria-expanded', String(!expanded));
                perfilToggle.textContent = expanded ? 'Ver más' : 'Ver menos';
            });
        }

        const initAudiovisualesSlider = (slidesId: string, nextId: string, totalSlides: number) => {
            const slides = document.getElementById(slidesId);
            const next = document.getElementById(nextId);
            let index = 0;

            const update = () => {
                if (!slides || !next) {
                    return;
                }

                slides.style.transform = `translateX(-${index * 100}%)`;
                next.setAttribute('aria-label', 'Mostrar siguiente video');
            };

            if (slides && next) {
                update();
                next.addEventListener('click', () => {
                    index = (index + 1) % totalSlides;
                    update();
                });
            }
        };

        initAudiovisualesSlider('audiovisuales-slides', 'audiovisuales-next', 11);
        initAudiovisualesSlider('audiovisuales-slides-2', 'audiovisuales-next-2', 4);
        initAudiovisualesSlider('audiovisuales-slides-3', 'audiovisuales-next-3', 5);

    </script>
