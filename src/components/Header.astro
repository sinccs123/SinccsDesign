---
import BotonReact from '../components/BotonReact.jsx';

const { pathname } = Astro.url;

const navLinks = [
    { name: 'Sobre mi', href: '/' },
    { name: 'Porfolio', href: '#' },
];
---
<header class="fixed top-0 left-0 w-full bg-white/90 dark:bg-slate-800/80 backdrop-blur-sm shadow-sm z-50 transition-colors duration-300">
    <nav class="mx-auto flex max-w-8xl items-center justify-between p-4 lg:px-8">
        <div class="flex items-center gap-4">
            <a href="/" class="-m-1.5 p-1.5">
                <img src="https://res.cloudinary.com/du83pwamg/image/upload/v1771861710/sinccs_bk_tou81s.png" alt="SinccsDesign" class="h-10 w-auto dark:hidden" />
                <img src="https://res.cloudinary.com/du83pwamg/image/upload/v1771861710/sinccs_col_peyzj4.png" alt="SinccsDesign" class="h-10 w-auto hidden dark:block" />
            </a>
        </div>
        <div class="flex items-center gap-x-6">
            <ul class="flex gap-x-6">
                {navLinks.map(link => (
                    <li>
                        <a
                            href={link.href}
                            class:list={[
                                "pb-1 text-lg font-semibold leading-6 text-gray-900 transition-colors duration-300 dark:text-gray-100 hover:text-gray-700 dark:hover:text-gray-300",
                                { 'border-b-2 border-yellow-400': pathname === link.href }
                            ]}
                        >{link.name}</a>
                    </li>
                ))}
            </ul>
            <BotonReact client:load />
        </div>
    </nav>
</header>